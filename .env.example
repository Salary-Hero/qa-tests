ENV=dev
APP_VERSION=10.0.0

# OTP is injected automatically from playwright.config.ts per ENV
# Set manually here only if you need to override
# OTP=111111

# Admin credentials — one set per environment, used for all QA companies on that env
ADMIN_EMAIL_DEV=
ADMIN_PASSWORD_DEV=
ADMIN_EMAIL_STAGING=
ADMIN_PASSWORD_STAGING=
ADMIN_EMAIL_PROD=
ADMIN_PASSWORD_PROD=

# Firebase API keys — one per environment
FIREBASE_API_KEY_DEV=
FIREBASE_API_KEY_STAGING=
FIREBASE_API_KEY_PROD=
