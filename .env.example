# QA Testing Configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# The _DEV and _STAGING suffix on each key means one file holds credentials
# for both environments. yarn test:api uses ENV=dev, yarn test:api:staging
# uses ENV=staging — the correct suffixed keys are loaded automatically.
#
# .env is gitignored — never commit it.

# Admin credentials
ADMIN_EMAIL_DEV=
ADMIN_PASSWORD_DEV=

ADMIN_EMAIL_STAGING=
ADMIN_PASSWORD_STAGING=

# Firebase API keys
FIREBASE_API_KEY_DEV=
FIREBASE_API_KEY_STAGING=

# LINE credentials (only needed for LINE signup tests)
LINE_CHANNEL_ID_DEV=
LINE_CHANNEL_SECRET_DEV=
LINE_REFRESH_TOKEN_DEV=

LINE_CHANNEL_ID_STAGING=
LINE_CHANNEL_SECRET_STAGING=
LINE_REFRESH_TOKEN_STAGING=

# Database connection
# DB_HOST, DB_PORT, DB_USER, DB_PASSWORD are shared — same RDS instance for both envs.
# DB_NAME differs per environment — dev and staging use separate databases on the same host.
DB_HOST=
DB_PORT=5432
DB_NAME_DEV=
DB_NAME_STAGING=
DB_USER=
DB_PASSWORD=