# QA Testing Configuration
#
# This project uses per-environment credential files:
#   .env.dev     → credentials for the dev environment
#   .env.staging → credentials for the staging environment
#
# To get started:
#   cp .env.example .env.dev
#   cp .env.example .env.staging
#
# Then fill in the correct values in each file.
# Both files are gitignored — never commit them.
#
# Scripts automatically load the correct file:
#   yarn test:api          → loads .env.dev
#   yarn test:api:staging  → loads .env.staging

# Admin credentials
ADMIN_EMAIL_DEV=
ADMIN_PASSWORD_DEV=

ADMIN_EMAIL_STAGING=
ADMIN_PASSWORD_STAGING=

# Firebase API keys
FIREBASE_API_KEY_DEV=
FIREBASE_API_KEY_STAGING=

# LINE credentials (only needed for LINE signup tests)
LINE_CHANNEL_ID_DEV=
LINE_CHANNEL_SECRET_DEV=
LINE_REFRESH_TOKEN_DEV=

LINE_CHANNEL_ID_STAGING=
LINE_CHANNEL_SECRET_STAGING=
LINE_REFRESH_TOKEN_STAGING=

# Database connection
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
